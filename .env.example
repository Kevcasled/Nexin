# Configuración del entorno (copiar a .env y rellenar)
APP_ENV=development
APP_URL=http://localhost:8080

# Base de datos
DB_HOST=db
DB_NAME=blog_db
DB_USER=blog_user
DB_PASS=blog_pass

# Webhook n8n (configurar con tu URL de n8n)
N8N_WEBHOOK_URL=

# Ollama (RAG)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
